<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Cyber Defense</title>
<style>
body {
    background:#0b0f14;
    color:#00ffcc;
    font-family:monospace;
    text-align:center;
}

table {
    width:100%;
    border-collapse:collapse;
    font-size:12px;
}
td,th {
    border:1px solid #00ffcc;
    padding:4px;
}

.screen { display:none; }
.active { display:block; }

#logContainer {
    height:300px;
    overflow-y:scroll;
}

button {
    background:black;
    color:#00ffcc;
    border:1px solid #00ffcc;
    padding:6px;
}

/* 中央寄せ配置 */
.mid {
    text-align:center;
}

/* 答え */
.correct { color:red; }

/* 少しだけ余白 */
.attackRow td {
    padding-top:8px;
    padding-bottom:8px;
}
</style>
</head>
<body>

<div id="startScreen" class="screen active">
<h1>🛡️ CYBER DEFENSE</h1>
<button onclick="goExplain()">START</button>
</div>

<div id="explainScreen" class="screen">
<h2>⚠ 判断基準</h2>
<p>① 国（CN / RU）</p>
<p>② アクセス回数（500以上）</p>
<p>③ ポート（22 / 3389）</p>
<button onclick="startCountdown()">NEXT</button>
</div>

<div id="countScreen" class="screen">
<h1 id="count">5</h1>
</div>

<div id="gameScreen" class="screen">
<h3 id="timer">Time: 60</h3>
<p>Score: <span id="score">0</span></p>

<div id="logContainer">
<table>
<thead>
<tr>
<th>TIME</th>
<th>IP</th>
<th>PATH</th>

<th class="mid">国</th>
<th class="mid">アクセス回数</th>
<th class="mid">PORT</th>

<th>UA</th>
<th>STATUS</th>
<th>操作</th>
</tr>
</thead>
<tbody id="log"></tbody>
</table>
</div>
</div>

<div id="endScreen" class="screen">
<h1>RESULT</h1>
<p id="finalScore"></p>
<p id="rank"></p>
<button onclick="restartGame()">🔁</button>
<button onclick="goHome()">🏠</button>
</div>

<script>
let score=0,timeLeft=60,gameState="start";
let audioCtx,bgmInterval;
let step=0;

// 画面
function showScreen(id){
 document.querySelectorAll(".screen").forEach(e=>e.classList.remove("active"));
 document.getElementById(id).classList.add("active");
}
function goExplain(){showScreen("explainScreen");}

// カウント
let count=5;
function startCountdown(){
 if(!audioCtx) audioCtx=new (window.AudioContext||window.webkitAudioContext)();
 count=5;
 showScreen("countScreen");

 let i=setInterval(()=>{
  document.getElementById("count").innerText=count;
  playSound("alert");
  count--;
  if(count<0){clearInterval(i);startGame();}
 },1000);
}

// ゲーム開始
function startGame(){
 score=0; timeLeft=60; gameState="playing";
 document.getElementById("score").innerText=score;
 document.getElementById("timer").innerText="Time: 60";
 document.getElementById("log").innerHTML="";
 startBGM();
 showScreen("gameScreen");
}

// 🎵 BGM（強化版）
const melody = [523,587,659,587,523,659,784,659];
const harmony = [392,440,392,330,392,440,392,330];

function playNote(){
 let m = melody[step % melody.length];
 let h = harmony[step % harmony.length];

 let o1=audioCtx.createOscillator(),g1=audioCtx.createGain();
 o1.type="square"; o1.frequency.value=m; g1.gain.value=0.02;
 o1.connect(g1); g1.connect(audioCtx.destination);
 o1.start(); o1.stop(audioCtx.currentTime+0.12);

 let o2=audioCtx.createOscillator(),g2=audioCtx.createGain();
 o2.type="square"; o2.frequency.value=h; g2.gain.value=0.015;
 o2.connect(g2); g2.connect(audioCtx.destination);
 o2.start(); o2.stop(audioCtx.currentTime+0.12);

 let bass=audioCtx.createOscillator(),gb=audioCtx.createGain();
 bass.type="square"; bass.frequency.value=m/2; gb.gain.value=0.01;
 bass.connect(gb); gb.connect(audioCtx.destination);
 bass.start(); bass.stop(audioCtx.currentTime+0.15);

 step++;
}

function startBGM(){
 bgmInterval=setInterval(playNote,180);
}
function stopBGM(){clearInterval(bgmInterval);}

// 音
function playSound(type){
 let o=audioCtx.createOscillator(),g=audioCtx.createGain();
 o.connect(g); g.connect(audioCtx.destination);
 if(type==="good") o.frequency.value=800;
 if(type==="bad") o.frequency.value=200;
 if(type==="alert") o.frequency.value=1000;
 g.gain.value=0.05;
 o.start(); o.stop(audioCtx.currentTime+0.1);
}

// データ
function randIP(){return `${Math.random()*255|0}.${Math.random()*255|0}.${Math.random()*255|0}.${Math.random()*255|0}`;}
function randTime(){return new Date().toLocaleTimeString();}
function pick(a){return a[Math.random()*a.length|0];}

function generateLog(){
 let country=pick(["JP","US","CN","RU"]);
 let port=pick([80,443,8080,22,3389]);

 let attack=(["CN","RU"].includes(country)&&(port==22||port==3389));
 let count=attack?500+(Math.random()*400|0):(Math.random()*100|0);

 if(timeLeft<30 && Math.random()<0.3){
  country="CN"; port=22; count=700; attack=false;
 }

 return {
  time:randTime(),
  ip:randIP(),
  country,
  count,
  port,
  path:pick(["/login","/api","/home","/admin"]),
  ua:pick(["Chrome","Safari","Edge","Bot"]),
  status:pick(["200","404","301","500"]),
  attack
 };
}

// 表示
function addLog(d){
 if(gameState!=="playing") return;

 let r=document.createElement("tr");

 let btn=document.createElement("button");
 btn.innerText="BLOCK";

 btn.onclick=function(){
  if(d.attack){
    score+=10;
    playSound("good");
    r.classList.add("attackRow");
  } else {
    score-=5;
    playSound("bad");
  }

  if(d.attack){
    r.children[3].classList.add("correct");
    r.children[4].classList.add("correct");
    r.children[5].classList.add("correct");
  }

  document.getElementById("score").innerText=score;
  btn.disabled=true;
  btn.innerText="DONE";
 };

 r.innerHTML=`
 <td>${d.time}</td>
 <td>${d.ip}</td>
 <td>${d.path}</td>

 <td class="mid">${d.country}</td>
 <td class="mid">${d.count}</td>
 <td class="mid">${d.port}</td>

 <td>${d.ua}</td>
 <td>${d.status}</td>
 `;

 let td=document.createElement("td");
 td.appendChild(btn);
 r.appendChild(td);

 document.getElementById("log").appendChild(r);
}

// ループ
function loop(){ if(gameState==="playing") addLog(generateLog()); }

// タイマー
function countdown(){
 if(gameState!=="playing") return;

 timeLeft--;
 document.getElementById("timer").innerText="Time: "+timeLeft;

 if(timeLeft<=0) endGame();
}

// 終了
function endGame(){
 gameState="end";
 stopBGM();

 let rank="B";
 if(score>300) rank="S";
 else if(score>150) rank="A";

 document.getElementById("finalScore").innerText="Score: "+score;
 document.getElementById("rank").innerText="Rank: "+rank;

 showScreen("endScreen");
}

function restartGame(){stopBGM();goExplain();}
function goHome(){stopBGM();showScreen("startScreen");}

setInterval(loop,500);
setInterval(countdown,1000);
</script>

</body>
</html>
